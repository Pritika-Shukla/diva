{
  "name": "diva",
  "description": "Ultra-compressed communication mode. Cuts ~75% of tokens while keeping full technical accuracy by speaking like a diva.",
  "author": {
    "name": "Pritika Shukla",
    "url": "https://github.com/Pritika-Shukla"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/diva-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading diva mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/diva-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking diva mode..."
          }
        ]
      }
    ]
  }
}
